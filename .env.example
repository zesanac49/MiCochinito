# ============================================================
#  Natillera — Variables de entorno
#  Copiar a .env (gitignored). NUNCA commitear secretos (doc 08 §5).
#  En Linux:  cp .env.example .env  &&  nano .env
# ============================================================

# ---------- Puerto del host (red local) ----------
# La app queda accesible en http://IP_DEL_SERVIDOR:APP_PORT
# La tienda usa 8080; Natillera usa 8090 por defecto. Cámbialo si está ocupado.
APP_PORT=8090

# ---------- Base de datos (MySQL propio en Docker) ----------
# DATABASE_URL NO se pone aquí: docker-compose la compone con estas credenciales.
MYSQL_DATABASE=natillera
MYSQL_USER=natillera
MYSQL_PASSWORD=cambia-esta-clave-de-bd
MYSQL_ROOT_PASSWORD=cambia-esta-clave-root

# ---------- App ----------
ENTORNO=prod                # local | test | prod
DEBUG=false
LOG_JSON=true
LOG_NIVEL=INFO

# ---------- Seguridad / JWT ----------
# Genera uno con:  openssl rand -hex 32
JWT_SECRET=genera-un-secreto-largo-y-aleatorio-de-al-menos-32-caracteres

# ---------- Administrador inicial ----------
# La app no tiene auto-registro: este usuario permite el primer ingreso.
# Al entrar, crea su natillera desde la interfaz y queda como ADMINISTRADOR.
ADMIN_EMAIL=admin@natillera.co
ADMIN_PASSWORD=cambia-esta-clave-de-admin
